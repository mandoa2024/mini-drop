DATABASE_URL=postgresql://drop:drop@postgres:5432/drop
SERVER_URL=http://server:8080
ANALYZER_URL=http://analyzer:8090
AGENT_ID=demo-agent
AGENT_NAME=demo-agent
AGENT_POLL_SECONDS=2
HEARTBEAT_SECONDS=5
DEMO_MODE=false

# Intelligent attribution. Copy this file to .env, then fill only the key.
ATTRIBUTION_ENABLED=true
ATTRIBUTION_MIN_BASELINE_SEGMENTS=3
ATTRIBUTION_BASELINE_SEGMENTS=5
ATTRIBUTION_CPU_DELTA_PP=12
ATTRIBUTION_MEMORY_RATIO=1.3
ATTRIBUTION_MAX_TOOL_CALLS=8

# Choose one provider: deepseek or openai.
LLM_PROVIDER=deepseek

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_REASONING_EFFORT=medium
# Thinking mode does not support tool_choice=required; the adapter uses auto.
DEEPSEEK_THINKING=true

# Optional OpenAI provider configuration.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
OPENAI_BASE_URL=https://api.openai.com/v1
